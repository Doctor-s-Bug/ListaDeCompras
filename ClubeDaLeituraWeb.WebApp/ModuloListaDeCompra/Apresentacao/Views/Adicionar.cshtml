@*
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Produtos";
    List<ListarProdutosViewModel> produtos = ViewBag.Produtos;
}
@model List<ListarItemViewModel>

<body>
    <a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">Cadastrar Novo</a>

    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger">
            @TempData["MensagemErro"]
        </div>
    }

    @if (@Model.Count == 0)
    {
        <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
            Nenhuma Categoria Cadastrada.
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (ListarItemViewModel item in Model)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <option value="">Selecione uma categoria</option>
                    @foreach (ListarProdutosViewModel produto in produtos)
                    {
                        <option value="@produto.Id">
                            @produto.Nome
                        </option>
                    }
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="card-title">R$@item.PrecoAproximado.ToString("F2")</h5>
                                <p class="card-text mb-2">
                                    <strong>Unidade: @item.UnidadeMedida</strong>
                                </p>
                            </div>
                            <div class="d-flex align-items-center">
                                <strong class="me-2">Categoria:</strong>
                                <span class="ms-2">@item.Categoria</span>
                            </div>
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3 mt-3 p-2" asp-action="Editar"
                               asp-route-id="@item.Id">Editar</a>
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3 mt-3 p-2" asp-action="Excluir"
                               asp-route-id="@item.Id">Excluir</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</body> *@
