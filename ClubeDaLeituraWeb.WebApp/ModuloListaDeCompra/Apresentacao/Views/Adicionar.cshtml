@{
    Layout = "_Layout";
    ViewBag.Titulo = "Adicionar Produto à Lista";
}

@model List<ListarItensProdutos>

@if (TempData["MensagemErro"] != null)
{
    <div class="alert alert-danger">
        @TempData["MensagemErro"]
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-primary border-start border-primary border-2 rounded-3">
        Nenhum Produto Cadastrado.
    </div>
}
else
{
    <div class="row g-3">

        @foreach (var item in Model)
        {
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">

                <form asp-action="AdicionarAoCarrinho" method="post">

                    <input type="hidden" name="ProdutoId" value="@item.Id" />

                    <div class="card shadow-sm h-100">
                        <div class="card-body">

                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="card-title">@item.ProdutoNome</h5>
                                <span class="badge text-bg-secondary fs-6">
                                    @item.Categoria
                                </span>
                            </div>
                            <hr />

                            <p class="card-text">
                                <strong>Preço:</strong>
                                R$ @item.Preco.ToString("F2")
                            </p>

                            <div class="mb-3">
                                <label class="form-label fw-semibold">
                                    Quantidade
                                </label>

                                <input type="number" name="Quantidade" value="1" min="1" class="form-control" />
                            </div>

                            <button type="submit" class="btn btn-success w-100 rounded-pill">
                                Adicionar
                            </button>

                        </div>
                    </div>

                </form>

            </div>
        }

    </div>
}