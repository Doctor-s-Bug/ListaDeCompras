@{
    Layout = "_Layout";
    ViewBag.Titulo = "Visualizar Lista";
}
@model ListarListasViewModel;

<div class="card border border-secondary  shadow-sm mx-auto p-4" style="max-width: 750px;">
    <div class="card shadow-sm h-100">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center fs-3">
                <p class="card-text mb-2">
                    <strong>Nome: @Model.Nome</strong>
                </p>
            </div>
            <div class="d-flex justify-content-between align-items-center fs-5">
                <p class="card-text mb-2">
                    <strong>Valor Total: R$ @Model.ValorTotal.ToString("F2")</strong>
                </p>
                <p class="card-text mb-2">
                    <strong>Status:</strong> @Model.StatusLista
                </p>
            </div>

            <div class="table-responsive mt-3 ">
                <table class="table table-bordered align-middle">
                    <thead>
                        <tr>
                            <th>Produto</th>
                            <th>Categoria</th>
                            <th>Qtnd</th>
                            <th>Preço</th>
                            <th>Ações</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (ListarItensProdutos c in Model.Produtos)
                        {
                            <tr>
                                <td>@c.ProdutoNome</td>
                                <td>@c.Categoria</td>
                                <td>@c.Quantidade</td>
                                <td>R$@c.Preco</td>
                                <td>
                                    <form asp-action="Remover" method="post">
                                        <input type="hidden" name="ProdutoId" value="@c.Id" />
                                        <input type="hidden" name="ListaId" value="@Model.Id" />

                                        <button type="submit" class="btn btn-primary">
                                            Remover
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="d-flex justify-content-start gap-2 mt-4">
                    <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
                    <a class="btn btn-primary rounded-pill px-4" asp-action="Adicionar"
                       asp-route-id="@Model.Id">Adicionar
                        Produto</a>
                    </div>
                </div>
            </div>
        </div>