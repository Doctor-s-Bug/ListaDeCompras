@using ClubeDaLeituraWeb.WebApp.ModuloCategoria.Dominio
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Cadastrar Produto";
}
@model CadastrarCategoriaViewModel;

<body>
    <form class="card border border-secondary  shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Cadastrar"
          method="post">
        <div class="">
            <label asp-for="Nome" class="form-label fw-semibold text-uppercase small mt-3 fs-4">Nome</label>
            <input asp-for="Nome" type="text" class="form-control fs-5">
            <span asp-validation-for="Nome" class="text-danger small fw-semibold"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Cor" class="form-label fw-semibold text-uppercase small mt-3 fs-5">Cor
                Categoria</label>
                <div>
                    <select asp-for="Cor" value="" class="form-select fs-4">
                        <option href="#">@CorCategoria.Branco.ToString()</option>
                        <option href="#">@CorCategoria.Azul.ToString()</option>
                        <option href="#">@CorCategoria.Verde.ToString()</option>
                        <option href="#">@CorCategoria.Vermelho.ToString()</option>
                    </select>
                    <span asp-validation-for="Cor" class="text-danger small fw-semibold"></span>
                </div>
                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
                    <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
                </div>
            </form>
        </body>